# Aerumentis — Environment Configuration
# Copy to .env and fill in your values

APP_NAME=Aerumentis
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

SECRET_KEY=change-me-to-a-secure-256-bit-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_PREFIX=aer_

DATABASE_URL=postgresql+asyncpg://aerumentis:aerumentis@localhost:5432/aerumentis
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=aerumentis
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4o
CHAT_MODEL_FALLBACK=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=120

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.70
RAG_MAX_CONTEXT_TOKENS=12000
RAG_ENABLE_RERANKING=false
RAG_ENABLE_QUERY_REWRITING=true
RAG_ENABLE_CITATIONS=true
